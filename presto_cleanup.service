[Unit]
Description=Remove old data from Presto Iceberg tables
After=presto_to_hcd.service


[Service]
Type=simple
Environment=PATH=/home/watsonx/affiliate-junction-demo/.venv/bin:/usr/local/bin:/usr/bin:/bin
Environment=VIRTUAL_ENV=/home/watsonx/affiliate-junction-demo/.venv
ExecStart=/home/watsonx/affiliate-junction-demo/.venv/bin/python /home/watsonx/affiliate-junction-demo/presto_cleanup.py
Restart=on-failure
User=watsonx

[Install]
WantedBy=multi-user.target
